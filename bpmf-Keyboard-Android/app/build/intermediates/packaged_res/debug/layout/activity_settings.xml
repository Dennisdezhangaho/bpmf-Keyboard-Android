<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top green area with settings icon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4"
        android:background="#00BE5A">

        <ImageButton
            android:id="@+id/btnGear"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#FFFFFF"
            android:contentDescription="Open keyboard settings"/>
    </FrameLayout>

    <!-- Options area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.6"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Options"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnAutoSpace"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Auto Space Off"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAutoCaps"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Auto Caps Off"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnDarkMode"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Dark Mode Off"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnFirstTone"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="First Tone Off"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/footer_text"
        android:textSize="14sp"
        android:textColor="#555555"
        android:textAlignment="center"
        android:paddingBottom="16dp"/>

</LinearLayout>
