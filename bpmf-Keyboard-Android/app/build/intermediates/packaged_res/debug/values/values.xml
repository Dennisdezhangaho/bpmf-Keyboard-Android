<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_green">#00BE5A</color>
    <color name="delete_tint">#FF3B30</color>
    <color name="key_bg">#AEAEB2</color>
    <color name="key_bg_dark">#1C1C1E</color>
    <color name="key_text">#FFFFFF</color>
    <color name="keyboard_bg">#000000</color>
    <color name="shift_active">#00C85A</color>
    <color name="tone_row_bg">#000000</color>
    <dimen name="func_delete_width">48dp</dimen>
    <dimen name="func_globe_width">44dp</dimen>
    <dimen name="func_return_width">80dp</dimen>
    <dimen name="func_secondary_width">52dp</dimen>
    <dimen name="func_shift_width">48dp</dimen>
    <dimen name="func_third_width">48dp</dimen>
    <dimen name="key_margin_h">2dp</dimen>
    <dimen name="key_row_height">48dp</dimen>
    <dimen name="key_row_margin_top">3dp</dimen>
    <string name="app_name">bopomofo Keyboard</string>
    <string name="footer_text">bopomofo Keyboard @Dennis Li 2026</string>
    <string name="ime_name">Bopomofo Keyboard</string>
    <string name="open_ime_settings">Open Input Method Settings</string>
    <string name="settings_title">Keyboard Settings</string>
    <string name="subtype_label">Bopomofo</string>
    <style name="FuncKey">
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@drawable/func_key_bg_selector</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">15sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="LetterKey">
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">@dimen/key_margin_h</item>
        <item name="android:layout_marginEnd">@dimen/key_margin_h</item>
        <item name="android:background">@drawable/key_bg_selector</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="ToneKey">
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>
</resources>